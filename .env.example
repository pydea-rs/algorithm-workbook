# Copy this file to `.env` and fill in a real hash. `.env` is gitignored and is
# blocked from the web by router.php — launch the PHP server with:
#   php -S localhost:8000 router.php
#
# Bcrypt hash of the login password. Generate one with:
#   php -r 'echo password_hash("your-password", PASSWORD_DEFAULT), "\n";'
JOURNEY_PASSWORD_HASH=

# Days a successful login stays valid before the password is asked again.
SESSION_EXPIRY_DAYS=7
